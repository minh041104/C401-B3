# Day 08 Lab — RAG Pipeline
# Cấu hình cho Sprint 2 Baseline

# === LLM Provider ===
LLM_PROVIDER=openai

# OpenAI API Key (lấy từ https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-YOUR_API_KEY_HERE

# Google Gemini Key (lấy từ https://aistudio.google.com/app/apikey)
# GOOGLE_API_KEY=YOUR_GEMINI_KEY_HERE

# Model mặc định
LLM_MODEL=gpt-4o-mini
# Hoặc nếu dùng Gemini:
# GEMINI_MODEL=gemini-1.5-flash

# === Embedding ===
# Chọn "openai" hoặc "local" (sentence-transformers)
EMBEDDING_PROVIDER=openai

# Nếu EMBEDDING_PROVIDER=openai, sẽ dùng text-embedding-3-small
# Nếu EMBEDDING_PROVIDER=local, sẽ dùng:
# LOCAL_EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
